# Normalize line endings: text is LF in the repo, checked out native.
# Keeps Windows/macOS/Linux contributors from churning CRLF vs LF.
* text=auto eol=lf

# Binary assets — never touch.
*.png binary
*.ico binary
*.icns binary
*.jpg binary
*.mp4 binary
*.webm binary
*.gif binary
*.exe binary

# Shell scripts must stay LF.
*.sh text eol=lf
